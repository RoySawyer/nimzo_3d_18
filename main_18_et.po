#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Täisekraani kuvamise valik suurema malelaua kuvamiseks"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "kibitsingu mootori analüüsiaknaga (versioon 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Nimzo_3d versioonile 4.2 lisatud funktsioonid"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Mootori aken"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Mootori akna valikud"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Mootori akna värv"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Mootori paneeli värv"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Valige mootori akna taustavärv"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Valige mootori aknapaneeli värv"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Märkimisel kuvatakse mootori akna tööriistariba"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Mootori akna tööriistariba kõrguse määramine"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Näita mootori akna tööriistariba – Märkige tööriistariba kuvamiseks"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "mootori akna allosas."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Mootori akna tööriistariba kõrgus – määrake tööriistariba kõrgus pikslites."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Näita mootori akna tööriistariba"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Mootori akna tööriistariba kõrgus"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Mootori akna värv – värvi valimiseks klõpsake nuppu"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "mootori analüüsi akna taustavärv."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Mootoripaneeli värv – värvi valimiseks klõpsake nuppu"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "mootori analüüsi sisemise paneeli taustavärv."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Salvesta praegune mäng"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Loetle mängud praegusest failist"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Otsi andmebaasist praegust asukohta"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Mootor mängib mõlemalt poolt"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Mängi mootori vastu hinnatud mängu"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Pöörake laud ümber"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Seadke positsioon malelaual sisse"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Seadke mängukellad"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Valige avatav raamat ja valikud"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Määrake programmi üldised valikud"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Ava abifail"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Välju programmist"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Valige praegune mootor"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Ava täisekraani valikute dialoogiboks"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Sulge see aken"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Lisa esimene kibitzi rida loendikasti teisaldamiseks"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Lisa kõik kibitzi read teisaldamiseks loendiboksi"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (versioon 4.2) mitmekeelne,"
