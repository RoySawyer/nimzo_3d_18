#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Une option d'affichage plein écran permet de visualiser un échiquier plus grand."

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "avec une fenêtre d'analyse moteur pour commenter (version 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Fonctionnalités ajoutées à Nimzo_3d - version 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Fenêtre du moteur"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "options de fenêtre du moteur"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "couleur de la vitre du moteur"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "couleur du panneau moteur"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Sélectionnez la couleur d'arrière-plan de la fenêtre du moteur"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Sélectionnez la couleur du panneau de la vitre du moteur"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Cocher pour afficher la barre d'outils de la fenêtre du moteur"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Définir la hauteur de la barre d'outils de la fenêtre du moteur"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Afficher la barre d'outils de la fenêtre du moteur - Cocher pour afficher une barre d'outils"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "en bas de la vitre du moteur."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Hauteur de la barre d'outils de la fenêtre du moteur - Définissez la hauteur de la barre d'outils en pixels."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Afficher la barre d'outils de la fenêtre du moteur"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "hauteur de la barre d'outils de la fenêtre du moteur"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Couleur de la vitre du moteur - Cliquez sur le bouton de couleur pour sélectionner"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "la couleur de fond de la fenêtre d'analyse du moteur."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Couleur du tableau de bord moteur - Cliquez sur le bouton de couleur pour sélectionner"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "Couleur de fond du panneau intérieur d'analyse du moteur."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Sauvegarder la partie en cours"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Liste des jeux du fichier actuel"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Rechercher la position actuelle dans la base de données"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Le moteur joue sur les deux tableaux."

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Jouez une partie classée contre un moteur d'entraînement."

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Retournez le plateau"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Installez-vous sur l'échiquier."

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Réglez les horloges du jeu"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Sélectionnez le livre d'ouverture et les options"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Définissez les options générales du programme"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Ouvrir le fichier d'aide"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Quitter le programme"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Sélectionnez le moteur actuel"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Ouvrir la boîte de dialogue des options plein écran"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Fermer cette fenêtre"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Ajouter la première ligne kibitz pour déplacer la zone de liste"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Ajouter toutes les lignes kibitz à la zone de liste de déplacement"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (version 4.2) multilingue,"
