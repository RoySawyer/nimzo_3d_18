#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "شطرنج کا بڑا بورڈ دکھانے کے لیے فل سکرین ڈسپلے کا اختیار"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "کیبٹزنگ کے لیے انجن کے تجزیہ کی کھڑکی کے ساتھ (ورژن 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Nimzo_3d - ورژن 4.2 میں خصوصیات شامل کی گئیں۔"

#: main_18.cpp:8
msgid "Engine window"
msgstr "انجن کی کھڑکی"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "انجن ونڈو کے اختیارات"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "انجن ونڈو کا رنگ"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "انجن پینل کا رنگ"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "انجن ونڈو کے پس منظر کا رنگ منتخب کریں۔"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "انجن ونڈو پینل کا رنگ منتخب کریں۔"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "انجن ونڈو ٹول بار دکھانے کے لیے چیک کریں۔"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "انجن ونڈو ٹول بار کی اونچائی سیٹ کریں۔"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "انجن ونڈو ٹول بار دکھائیں - ٹول بار دکھانے کے لیے چیک کریں۔"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "انجن کی کھڑکی کے نیچے۔"

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "انجن ونڈو ٹول بار کی اونچائی - ٹول بار کی اونچائی کو پکسلز میں سیٹ کریں۔"

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "انجن ونڈو ٹول بار دکھائیں۔"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "انجن ونڈو ٹول بار کی اونچائی"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "انجن ونڈو کا رنگ - منتخب کرنے کے لیے رنگ کنٹرول پر کلک کریں۔"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "انجن کے تجزیہ کی کھڑکی کے لیے پس منظر کا رنگ۔"

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "انجن پینل کا رنگ - منتخب کرنے کے لیے رنگ کنٹرول پر کلک کریں۔"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "انجن کے تجزیہ کے اندرونی پینل کے لیے پس منظر کا رنگ۔"

#: main_18.cpp:38
msgid "Save current game"
msgstr "موجودہ کھیل کو محفوظ کریں۔"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "موجودہ فائل سے گیمز کی فہرست بنائیں"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "موجودہ پوزیشن کے لیے ڈیٹا بیس تلاش کریں۔"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "انجن دونوں طرف سے کھیلتا ہے۔"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "انجن کے خلاف ریٹیڈ گیم کھیلیں"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "بورڈ پلٹائیں"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "شطرنج کے بورڈ پر پوزیشن قائم کریں۔"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "گیم کی گھڑیاں سیٹ کریں۔"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "ابتدائی کتاب اور اختیارات منتخب کریں۔"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "پروگرام کے لیے عمومی اختیارات مرتب کریں۔"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "مدد کی فائل کھولیں۔"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "پروگرام سے باہر نکلیں۔"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "موجودہ انجن کو منتخب کریں۔"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "فل سکرین آپشنز ڈائیلاگ باکس کھولیں۔"

#: main_18.cpp:53
msgid "Close this window"
msgstr "اس کھڑکی کو بند کرو"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "لسٹ باکس کو منتقل کرنے کے لیے پہلی کبٹز لائن شامل کریں۔"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "لسٹ باکس کو منتقل کرنے کے لیے تمام کیبٹز لائنیں شامل کریں۔"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (ورژن 4.2) کثیر لسانی،"
