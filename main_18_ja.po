#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "より大きなチェス盤を表示するためのフルスクリーン表示オプション"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "エンジン分析ウィンドウ（バージョン4.2）"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Nimzo_3d バージョン 4.2 に追加された機能"

#: main_18.cpp:8
msgid "Engine window"
msgstr "エンジンウィンドウ"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "エンジンウィンドウのオプション"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "エンジンウィンドウの色"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "エンジンパネルの色"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "エンジンウィンドウの背景色を選択する"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "エンジンウィンドウパネルの色を選択する"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "エンジンウィンドウのツールバーを表示するにはチェックを入れます"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "エンジンウィンドウのツールバーの高さを設定する"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "エンジンウィンドウのツールバーを表示 - ツールバーを表示するにはチェックを入れます"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "エンジンウィンドウの下部にあります。"

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "エンジン ウィンドウのツールバーの高さ - ツールバーの高さをピクセル単位で設定します。"

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "エンジンウィンドウのツールバーを表示"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "エンジンウィンドウのツールバーの高さ"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "エンジンウィンドウの色 - 色コントロールをクリックして選択します"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "エンジン分析ウィンドウの背景色。"

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "エンジンパネルの色 - 色コントロールをクリックして選択します"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "エンジン解析内部パネルの背景色。"

#: main_18.cpp:38
msgid "Save current game"
msgstr "現在のゲームを保存する"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "現在のファイルからゲームを一覧表示する"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "現在の位置をデータベースで検索"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "エンジンは両方の側面を担う"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "エンジンと対戦してレーティングゲームをプレイする"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "ボードをひっくり返す"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "チェス盤上のポジションを設定する"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "ゲームクロックを設定する"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "オープニングブックとオプションを選択する"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "プログラムの一般オプションを設定する"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "ヘルプファイルを開く"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "プログラムを終了する"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "現在のエンジンを選択"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "全画面オプションダイアログボックスを開く"

#: main_18.cpp:53
msgid "Close this window"
msgstr "このウィンドウを閉じる"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "リストボックスを移動するための最初のキビッツ行を追加します"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "移動リストボックスにすべてのキビッツ行を追加します"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (バージョン 4.2) 多言語対応、"
