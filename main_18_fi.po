#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Koko näytön näyttövaihtoehto suuremman shakkilaudan näyttämiseksi"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "moottorianalyysi-ikkunalla kibitzingiä varten (versio 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Nimzo_3d:hen lisätyt ominaisuudet - versio 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Moottorin ikkuna"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Moottorin ikkunan vaihtoehdot"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Moottorin ikkunan väri"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Moottoripaneelin väri"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Valitse moottorin ikkunan taustaväri"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Valitse moottorin ikkunapaneelin väri"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Valitse tämä näyttääksesi moottorin ikkunan työkalupalkin"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Moottorin ikkunan työkalupalkin korkeuden asettaminen"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Näytä moottorin ikkunan työkalupalkki - Valitse tämä, jos haluat näyttää työkalupalkin"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "moottorin ikkunan alareunassa."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Moottorin ikkunan työkalupalkin korkeus - Aseta työkalupalkin korkeus pikseleinä."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Näytä moottorin ikkunan työkalupalkki"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Moottorin ikkunan työkalupalkin korkeus"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Moottorin ikkunan väri - Valitse väri napsauttamalla säädintä"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "moottorianalyysi-ikkunan taustaväri."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Moottoripaneelin väri – Valitse väri napsauttamalla säädintä"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "moottorianalyysin sisäpaneelin taustaväri."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Tallenna nykyinen peli"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Listaa pelit nykyisestä tiedostosta"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Hae nykyistä sijaintia tietokannasta"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Moottori pelaa molemmilla puolilla"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Pelaa luokiteltua peliä moottoria vastaan"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Käännä lauta ympäri"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Aseta paikka shakkilaudalla"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Aseta pelikellot"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Valitse aloituskirja ja asetukset"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Määritä ohjelman yleiset asetukset"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Avaa ohjetiedosto"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Poistu ohjelmasta"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Valitse nykyinen moottori"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Avaa koko näytön asetusten valintaikkuna"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Sulje tämä ikkuna"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Lisää ensimmäinen kibitz-rivi siirtoluetteloruutuun"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Lisää kaikki kibitz-rivit siirrettäväksi -luetteloruutu"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (versio 4.2) monikielinen,"
