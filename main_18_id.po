#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Opsi tampilan layar penuh untuk menampilkan papan catur yang lebih besar."

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "dengan jendela analisis mesin untuk mengamati (versi 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Fitur yang ditambahkan ke Nimzo_3d - versi 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Jendela mesin"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Opsi jendela mesin"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Warna jendela mesin"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Warna panel mesin"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Pilih warna latar belakang jendela mesin"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Pilih warna panel jendela mesin"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Centang untuk menampilkan bilah alat jendela mesin."

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Atur ketinggian bilah alat jendela mesin."

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Tampilkan bilah alat jendela mesin - Centang untuk menampilkan bilah alat"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "di bagian bawah jendela mesin."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Tinggi bilah alat jendela mesin - Atur tinggi bilah alat dalam piksel."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Tampilkan bilah alat jendela mesin"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Tinggi bilah alat jendela mesin"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Warna jendela mesin - Klik kontrol warna untuk memilih"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "Warna latar belakang untuk jendela analisis mesin."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Warna panel mesin - Klik kontrol warna untuk memilih"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "warna latar belakang untuk panel dalam analisis mesin."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Simpan permainan saat ini"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Daftar game dari file saat ini"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Cari posisi terkini di dalam basis data."

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Mesin memainkan kedua sisi"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Mainkan permainan berperingkat melawan mesin."

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Balik papan"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Tetapkan posisi di papan catur"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Atur jam permainan"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Pilih buku pembukaan dan opsi."

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Atur opsi umum untuk program tersebut."

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Buka berkas bantuan"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Keluar dari program"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Pilih mesin saat ini"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Buka kotak dialog opsi layar penuh."

#: main_18.cpp:53
msgid "Close this window"
msgstr "Tutup jendela ini"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Tambahkan baris komentar pertama ke kotak daftar pindahan"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Tambahkan semua baris komentar ke kotak daftar pindah."

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (versi 4.2) multibahasa,"
