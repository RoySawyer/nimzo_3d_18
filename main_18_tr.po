#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Daha büyük bir satranç tahtası göstermek için tam ekran görüntüleme seçeneği."

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "Motor analizi penceresiyle (sürüm 4.2) yorum yapma imkanı sunuyor."

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Nimzo_3d'ye yeni özellikler eklendi - sürüm 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Motor penceresi"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Motor penceresi seçenekleri"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Motor camı rengi"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Motor paneli rengi"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Motor penceresinin arka plan rengini seçin."

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Motor camı panelinin rengini seçin."

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Motor penceresi araç çubuğunu göstermek için işaretleyin."

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Motor penceresi araç çubuğunun yüksekliğini ayarlayın."

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Motor penceresi araç çubuğunu göster - Araç çubuğunu göstermek için işaretleyin."

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "Motor penceresinin alt kısmında."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Motor penceresi araç çubuğu yüksekliği - Araç çubuğunun yüksekliğini piksel cinsinden ayarlayın."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Motor penceresi araç çubuğunu göster"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Motor penceresi araç çubuğu yüksekliği"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Motor camı rengi - Seçmek için renk kontrolüne tıklayın."

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "Motor analiz penceresinin arka plan rengi."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Motor paneli rengi - Seçmek için renk kontrolüne tıklayın."

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "Motor analiz iç panelinin arka plan rengi."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Mevcut oyunu kaydet"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Mevcut dosyadaki oyunları listele"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Mevcut pozisyon için veritabanında arama yapın."

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Motor her iki tarafta da oynuyor"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Motorun karşılaştığı dereceli bir oyunu oynayın."

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Tahtayı ters çevirin"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Satranç tahtasında bir pozisyon oluşturun."

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Oyun saatlerini ayarlayın"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Açılış kitabını ve seçenekleri seçin."

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Program için genel seçenekleri ayarlayın."

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Yardım dosyasını açın"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Programdan çık"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Mevcut motoru seçin"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Tam ekran seçenekleri iletişim kutusunu açın."

#: main_18.cpp:53
msgid "Close this window"
msgstr "Bu pencereyi kapat"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Hareket listesi kutusuna ilk kibitz satırını ekleyin."

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Tüm yorum satırlarını taşıma listesi kutusuna ekle"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (sürüm 4.2) çok dilli,"
