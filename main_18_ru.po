#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Функция полноэкранного отображения для показа шахматной доски большего размера."

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "с окном анализа движка для комментариев (версия 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "В Nimzo_3d добавлены новые функции — версия 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Окно двигателя"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "варианты окон двигателя"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "цвет моторного стекла"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "цвет панели двигателя"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Выберите цвет фона окна двигателя."

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Выберите цвет панели окна двигателя."

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Установите флажок, чтобы отобразить панель инструментов в окне двигателя."

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Установите высоту панели инструментов окна двигателя."

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Показать панель инструментов окна двигателя — установите флажок, чтобы отобразить панель инструментов."

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "в нижней части окна двигателя."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Высота панели инструментов в окне двигателя — задайте высоту панели инструментов в пикселях."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Показать панель инструментов окна двигателя"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "высота панели инструментов окна двигателя"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Цвет иллюминатора двигателя — нажмите на кнопку выбора цвета."

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "Цвет фона окна анализа двигателя."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Цвет панели двигателя — нажмите на регулятор цвета, чтобы выбрать."

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "Цвет фона для внутренней панели анализа двигателя."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Сохранение текущей игры"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Список игр из текущего файла"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Поиск в базе данных по текущей вакансии"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Двигатель работает на обеих сторонах"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Сыграйте рейтинговую игру против движка."

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Переверните доску"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Расположите фигуру на шахматной доске."

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Установите игровые часы"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Выберите дебютную книгу и параметры."

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Настройте общие параметры программы."

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Откройте файл справки"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Выйти из программы"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Выберите текущий двигатель"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Откройте диалоговое окно параметров полноэкранного режима."

#: main_18.cpp:53
msgid "Close this window"
msgstr "Закройте это окно"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Добавьте первую строку kibitz в список перемещений."

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Добавить все строки Kibitz в список перемещений"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (версия 4.2) многоязычный,"
