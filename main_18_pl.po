#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Opcja wyświetlania na pełnym ekranie, umożliwiająca wyświetlanie większej szachownicy"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "z oknem analizy silnika do kibicowania (wersja 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Funkcje dodane do Nimzo_3d – wersja 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Okno silnika"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Opcje okna silnika"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Kolor okna silnika"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Kolor panelu silnika"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Wybierz kolor tła okna silnika"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Wybierz kolor panelu okna silnika"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Zaznacz, aby wyświetlić pasek narzędzi okna silnika"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Ustaw wysokość paska narzędzi okna silnika"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Pokaż pasek narzędzi okna silnika – zaznacz, aby wyświetlić pasek narzędzi"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "na dole okna silnika."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Wysokość paska narzędzi okna silnika — ustaw wysokość paska narzędzi w pikselach."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Pokaż pasek narzędzi okna silnika"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Wysokość paska narzędzi okna silnika"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Kolor okna silnika – Kliknij kontrolkę koloru, aby wybrać"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "kolor tła okna analizy silnika."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Kolor panelu silnika – Kliknij kontrolkę koloru, aby wybrać"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "kolor tła wewnętrznego panelu analizy silnika."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Zapisz bieżącą grę"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Wyświetl listę gier z bieżącego pliku"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Wyszukaj w bazie danych aktualną pozycję"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Silnik gra po obu stronach"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Zagraj w grę z oceną przeciwko silnikowi"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Odwróć planszę"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Ustaw pozycję na szachownicy"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Ustaw zegary gry"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Wybierz książkę otwierającą i opcje"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Ustaw ogólne opcje programu"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Otwórz plik pomocy"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Wyjdź z programu"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Wybierz aktualny silnik"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Otwórz okno dialogowe opcji pełnego ekranu"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Zamknij to okno"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Dodaj pierwszą linię kibitz do listy przeniesień"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Dodaj wszystkie linie kibitz do listy przeniesień"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (wersja 4.2) wielojęzyczna,"
