#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "خيار عرض ملء الشاشة لعرض رقعة شطرنج أكبر"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "مع نافذة تحليل المحرك للتعليقات (الإصدار 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "ميزات جديدة تمت إضافتها إلى Nimzo_3d - الإصدار 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "نافذة المحرك"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "خيارات نافذة المحرك"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "لون نافذة المحرك"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "لون لوحة المحرك"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "حدد لون خلفية نافذة المحرك"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "اختر لون لوحة نافذة المحرك"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "فعّل خيار إظهار شريط أدوات نافذة المحرك"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "اضبط ارتفاع شريط أدوات نافذة المحرك"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "إظهار شريط أدوات نافذة المحرك - حدد هذا الخيار لإظهار شريط الأدوات"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "في أسفل نافذة المحرك."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "ارتفاع شريط أدوات نافذة المحرك - اضبط ارتفاع شريط الأدوات بالبكسل."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "عرض شريط أدوات نافذة المحرك"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "ارتفاع شريط أدوات نافذة المحرك"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "لون نافذة المحرك - انقر فوق عنصر التحكم في اللون لتحديده"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "لون خلفية نافذة تحليل المحرك."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "لون لوحة المحرك - انقر فوق عنصر التحكم في اللون لتحديده"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "لون الخلفية للوحة الداخلية لتحليل المحرك."

#: main_18.cpp:38
msgid "Save current game"
msgstr "احفظ اللعبة الحالية"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "قائمة الألعاب من الملف الحالي"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "ابحث في قاعدة البيانات عن الوظيفة الحالية"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "يلعب المحرك كلا الجانبين"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "العب مباراة مصنفة ضد محرك ألعاب"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "اقلب اللوحة"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "حدد موقعًا على رقعة الشطرنج"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "اضبط ساعات اللعبة"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "اختر كتاب الافتتاح والخيارات"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "اضبط الخيارات العامة للبرنامج"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "افتح ملف المساعدة"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "الخروج من البرنامج"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "حدد المحرك الحالي"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "افتح مربع حوار خيارات ملء الشاشة"

#: main_18.cpp:53
msgid "Close this window"
msgstr "أغلق هذه النافذة"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "أضف سطر التعليقات الأول إلى مربع قائمة النقل"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "أضف جميع تعليقات المشاركين إلى مربع قائمة النقل"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (الإصدار 4.2) متعدد اللغات،"
