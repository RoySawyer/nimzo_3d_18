#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Опция за показване на цял екран, за да се покаже по-голяма шахматна дъска"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "с прозорец за анализ на двигателя за кибицове (версия 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Добавени функции към Nimzo_3d - версия 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Прозорец на двигателя"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Опции за прозореца на двигателя"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Цвят на прозореца на двигателя"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Цвят на панела на двигателя"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Изберете цвета на фона на прозореца на двигателя"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Изберете цвят на панела на прозореца на двигателя"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Отметнете, за да се покаже лентата с инструменти на прозореца на двигателя"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Задаване на височината на лентата с инструменти на прозореца на двигателя"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Показване на лентата с инструменти на прозореца на двигателя - Отметнете, за да се покаже лентата с инструменти"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "в долната част на прозореца на двигателя."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Височина на лентата с инструменти на прозореца на двигателя - Задайте височината на лентата с инструменти в пиксели."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Показване на лентата с инструменти на прозореца на двигателя"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Височина на инструменталната лента на прозореца на двигателя"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Цвят на прозореца на двигателя - Кликнете върху контролата за цвят, за да изберете"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "цветът на фона за прозореца за анализ на двигателя."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Цвят на панела на двигателя - Кликнете върху контролата за цвят, за да изберете"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "цветът на фона за вътрешния панел за анализ на двигателя."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Запазване на текущата игра"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Избройте игрите от текущия файл"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Търсене в базата данни за текущата позиция"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Двигателят играе и на двете страни"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Играйте рейтингова игра срещу енджина"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Обърнете дъската"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Задайте позиция на шахматната дъска"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Настройте часовниците за игра"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Изберете началната книга и опциите"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Задайте общите опции за програмата"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Отворете файла с помощ"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Излезте от програмата"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Изберете текущия двигател"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Отваряне на диалоговия прозорец с опции за цял екран"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Затвори този прозорец"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Добавяне на първи кибитов ред за преместване на списъчното поле"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Добавете всички кибицови редове, за да преместите списъчното поле"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (версия 4.2) многоезичен,"
