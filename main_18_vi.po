#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Tùy chọn hiển thị toàn màn hình để hiển thị bàn cờ lớn hơn"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "với cửa sổ phân tích động cơ để bình luận (phiên bản 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Các tính năng được thêm vào Nimzo_3d - phiên bản 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Cửa sổ động cơ"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Tùy chọn cửa sổ động cơ"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "màu cửa sổ động cơ"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "màu tấm động cơ"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Chọn màu nền cho cửa sổ động cơ"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Chọn màu sắc cho tấm ốp cửa sổ động cơ."

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Chọn để hiển thị thanh công cụ cửa sổ công cụ"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Đặt chiều cao thanh công cụ cửa sổ công cụ"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Hiển thị thanh công cụ cửa sổ công cụ - Chọn để hiển thị thanh công cụ"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "ở phía dưới cửa sổ khoang động cơ."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Chiều cao thanh công cụ cửa sổ Engine - Đặt chiều cao thanh công cụ theo pixel."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Thanh công cụ cửa sổ hiển thị công cụ"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Chiều cao thanh công cụ cửa sổ động cơ"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Màu cửa sổ động cơ - Nhấp vào nút điều khiển màu để chọn"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "Màu nền cho cửa sổ phân tích động cơ."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Màu sắc bảng điều khiển động cơ - Nhấp vào nút điều khiển màu để chọn"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "Màu nền cho bảng điều khiển bên trong phân tích động cơ."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Lưu trò chơi hiện tại"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Liệt kê các trò chơi từ tệp hiện tại"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Tìm kiếm trong cơ sở dữ liệu vị trí hiện tại"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Động cơ đóng vai trò hai mặt"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Chơi một ván đấu xếp hạng với máy tính."

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Lật tấm ván"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Sắp xếp vị trí trên bàn cờ."

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Đặt đồng hồ trò chơi"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Chọn sách khai cuộc và các tùy chọn"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Thiết lập các tùy chọn chung cho chương trình."

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Mở tệp trợ giúp"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Thoát khỏi chương trình"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Chọn công cụ hiện tại"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Mở hộp thoại tùy chọn toàn màn hình"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Đóng cửa sổ này"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Thêm dòng góp ý đầu tiên vào hộp danh sách di chuyển"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Thêm tất cả các dòng bình luận vào hộp danh sách di chuyển"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (phiên bản 4.2) đa ngôn ngữ,"
