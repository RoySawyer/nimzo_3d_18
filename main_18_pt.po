#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Uma opção de exibição em tela cheia para mostrar um tabuleiro de xadrez maior."

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "com uma janela de análise do motor para comentários (versão 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Funcionalidades adicionadas ao Nimzo_3d - versão 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Janela do motor"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Opções de janela do motor"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Cor da janela do motor"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Cor do painel do motor"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Selecione a cor de fundo da janela do motor."

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Selecione a cor do painel da janela do motor."

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Verifique se a barra de ferramentas da janela do motor está visível."

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Defina a altura da barra de ferramentas da janela do motor."

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Exibir barra de ferramentas da janela do motor - Marque esta opção para exibir a barra de ferramentas."

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "na parte inferior da janela do motor."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Altura da barra de ferramentas da janela do motor - Defina a altura da barra de ferramentas em pixels."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Exibir barra de ferramentas da janela do motor"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "altura da barra de ferramentas da janela do motor"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Cor da janela do motor - Clique no controle de cores para selecionar."

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "A cor de fundo da janela de análise do motor."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Cor do painel do motor - Clique no controle de cores para selecionar."

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "A cor de fundo para o painel interno de análise do motor."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Salvar jogo atual"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Listar jogos do arquivo atual"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Pesquisar na base de dados a posição atual"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "O motor joga dos dois lados"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Jogue uma partida ranqueada contra um motor de jogo."

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Vire o tabuleiro"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Configure uma posição no tabuleiro de xadrez."

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Ajuste os relógios do jogo"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Selecione o livro de abertura e as opções."

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Defina as opções gerais do programa."

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Abra o arquivo de ajuda."

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Sair do programa"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Selecione o motor atual"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Abra a caixa de diálogo de opções de tela cheia."

#: main_18.cpp:53
msgid "Close this window"
msgstr "Feche esta janela."

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Adicione a primeira linha do Kibitz para mover a caixa de listagem."

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Adicionar todas as linhas do Kibitz para mover a caixa de listagem"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (versão 4.2) multilíngue,"
