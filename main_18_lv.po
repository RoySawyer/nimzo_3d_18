#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Pilnekrāna displeja opcija, lai parādītu lielāku šaha galdiņu"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "ar dzinēja analīzes logu kibitzing (4.2. versija)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Nimzo_3d — 4.2 versijai pievienotās funkcijas"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Dzinēja logs"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Dzinēja logu opcijas"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Dzinēja loga krāsa"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Dzinēja paneļa krāsa"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Izvēlieties dzinēja loga fona krāsu"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Izvēlieties dzinēja loga paneļa krāsu"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Atzīmējiet, lai rādītu dzinēja loga rīkjoslu"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Iestatiet dzinēja loga rīkjoslas augstumu"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Rādīt dzinēja loga rīkjoslu — atzīmējiet, lai parādītu rīkjoslu"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "dzinēja loga apakšā."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Dzinēja loga rīkjoslas augstums — iestatiet rīkjoslas augstumu pikseļos."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Rādīt dzinēja loga rīkjoslu"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Dzinēja loga rīkjoslas augstums"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Dzinēja loga krāsa — noklikšķiniet uz krāsas vadības elementa, lai to atlasītu"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "dzinēja analīzes loga fona krāsa."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Dzinēja paneļa krāsa — noklikšķiniet uz krāsas vadības elementa, lai to atlasītu"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "Dzinēja analīzes iekšējā paneļa fona krāsa."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Saglabāt pašreizējo spēli"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Uzskaitīt spēles no pašreizējā faila"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Meklēt datubāzē pašreizējo atrašanās vietu"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Dzinējs darbojas abās pusēs"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Spēlējiet novērtētu spēli pret dzinēju"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Apgrieziet dēli otrādi"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Iestatiet pozīciju šaha galdiņā"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Iestatiet spēles pulksteņus"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Atlasiet atveramo grāmatu un opcijas"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Iestatiet programmas vispārīgās opcijas"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Atveriet palīdzības failu"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Iziet no programmas"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Atlasiet pašreizējo dzinēju"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Atvērt pilnekrāna režīma opciju dialoglodziņu"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Aizvērt šo logu"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Pievienot pirmo kibitz rindu, lai pārvietotu saraksta lodziņu"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Pievienot visas kibitz līnijas, lai pārvietotu saraksta lodziņu"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (4.2. versija) daudzvalodu,"
