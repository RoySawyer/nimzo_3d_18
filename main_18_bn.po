#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "একটি বৃহত্তর দাবা বোর্ড দেখানোর জন্য একটি পূর্ণ স্ক্রিন প্রদর্শনের বিকল্প"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "কিবিটজিংয়ের জন্য একটি ইঞ্জিন বিশ্লেষণ উইন্ডো সহ (সংস্করণ 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Nimzo_3d - সংস্করণ 4.2-এ বৈশিষ্ট্য যোগ করা হয়েছে"

#: main_18.cpp:8
msgid "Engine window"
msgstr "ইঞ্জিনের জানালা"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "ইঞ্জিন উইন্ডো বিকল্পগুলি"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "ইঞ্জিনের জানালার রঙ"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "ইঞ্জিন প্যানেলের রঙ"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "ইঞ্জিন উইন্ডোর পটভূমির রঙ নির্বাচন করুন"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "ইঞ্জিনের জানালার প্যানেলের রঙ নির্বাচন করুন"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "ইঞ্জিন উইন্ডো টুলবারটি দেখতে চেক করুন।"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "ইঞ্জিন উইন্ডো টুলবারের উচ্চতা সেট করুন"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "ইঞ্জিন উইন্ডো টুলবার দেখান - একটি টুলবার দেখানোর জন্য চেক করুন"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "ইঞ্জিনের জানালার নীচে।"

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "ইঞ্জিন উইন্ডো টুলবারের উচ্চতা - টুলবারের উচ্চতা পিক্সেলে সেট করুন।"

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "ইঞ্জিন উইন্ডো টুলবার দেখান"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "ইঞ্জিন উইন্ডো টুলবারের উচ্চতা"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "ইঞ্জিন উইন্ডোর রঙ - নির্বাচন করতে রঙ নিয়ন্ত্রণে ক্লিক করুন"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "ইঞ্জিন বিশ্লেষণ উইন্ডোর পটভূমির রঙ।"

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "ইঞ্জিন প্যানেলের রঙ - নির্বাচন করতে রঙ নিয়ন্ত্রণে ক্লিক করুন"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "ইঞ্জিন বিশ্লেষণের ভেতরের প্যানেলের পটভূমির রঙ।"

#: main_18.cpp:38
msgid "Save current game"
msgstr "বর্তমান খেলাটি সংরক্ষণ করুন"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "বর্তমান ফাইল থেকে গেম তালিকাভুক্ত করুন"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "বর্তমান অবস্থানের জন্য ডাটাবেস অনুসন্ধান করুন"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "ইঞ্জিন উভয় দিকেই কাজ করে"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "একটি ইঞ্জিনের বিরুদ্ধে একটি রেট করা খেলা খেলুন"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "বোর্ড উল্টে দিন"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "দাবা বোর্ডে একটি অবস্থান সেট আপ করুন"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "খেলার ঘড়ি সেট করুন"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "খোলার বই এবং বিকল্পগুলি নির্বাচন করুন"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "প্রোগ্রামের জন্য সাধারণ বিকল্পগুলি সেট করুন"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "সাহায্য ফাইলটি খুলুন।"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "প্রোগ্রাম থেকে বেরিয়ে আসুন"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "বর্তমান ইঞ্জিনটি নির্বাচন করুন"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "পূর্ণ পর্দার বিকল্পগুলির ডায়ালগ বক্স খুলুন।"

#: main_18.cpp:53
msgid "Close this window"
msgstr "এই জানালাটি বন্ধ করুন"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "তালিকা বাক্স সরাতে প্রথম কিবিটজ লাইন যোগ করুন"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "তালিকা বাক্স সরাতে সকল কিবিটজ লাইন যোগ করুন"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (সংস্করণ 4.2) বহুভাষিক,"
