#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Ett alternativ för helskärmsvisning för att visa ett större schackbräde"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "med ett motoranalysfönster för kibitzing (version 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Funktioner tillagda i Nimzo_3d - version 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Motorfönster"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Alternativ för motorfönstret"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Färg på motorfönstret"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Färg på motorpanelen"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Välj bakgrundsfärg för motorfönstret"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Välj färg på motorfönstrets panel"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Markera om du vill visa verktygsfältet i motorfönstret"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Ställ in höjden på motorfönstrets verktygsfält"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Visa verktygsfältet i motorfönstret – Markera om du vill visa ett verktygsfält"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "längst ner i motorfönstret."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Höjd på verktygsfältet i motorfönstret – Ange verktygsfältets höjd i pixlar."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Visa verktygsfältet för motorfönstret"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Höjd på verktygsfältet för motorfönstret"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Färg på motorfönstret – Klicka på färgkontrollen för att välja"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "bakgrundsfärgen för motoranalysfönstret."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Färg på motorpanelen – Klicka på färgkontrollen för att välja"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "bakgrundsfärgen för motoranalysens inre panel."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Spara aktuellt spel"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Lista spel från aktuell fil"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Sök i databasen efter aktuell position"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Motorn spelar på båda sidor"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Spela ett klassificerat spel mot en motor"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Vänd brädet"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Ställ in en position på schackbrädet"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Ställ in matchklockorna"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Välj öppningsboken och alternativen"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Ställ in de allmänna alternativen för programmet"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Öppna hjälpfilen"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Avsluta programmet"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Välj den aktuella motorn"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Öppna dialogrutan för helskärmsalternativ"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Stäng det här fönstret"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Lägg till första kibitz-raden i flyttlistrutan"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Lägg till alla Kibitz-rader i flyttlistrutan"

