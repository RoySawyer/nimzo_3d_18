#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "گزینه نمایش تمام صفحه برای نمایش صفحه شطرنج بزرگتر"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "با پنجره تحلیل موتور برای کیبیتسینگ (نسخه ۴.۲)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "ویژگی‌های اضافه شده به Nimzo_3d - نسخه ۴.۲"

#: main_18.cpp:8
msgid "Engine window"
msgstr "پنجره موتور"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "گزینه‌های پنجره موتور"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "رنگ شیشه موتور"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "رنگ پنل موتور"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "رنگ پس زمینه پنجره موتور را انتخاب کنید"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "رنگ پنل پنجره موتور را انتخاب کنید"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "برای نمایش نوار ابزار پنجره موتور، تیک بزنید"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "ارتفاع نوار ابزار پنجره موتور را تنظیم کنید"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "نمایش نوار ابزار پنجره موتور - برای نمایش نوار ابزار، علامت بزنید"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "در پایین پنجره موتور."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "ارتفاع نوار ابزار پنجره موتور - ارتفاع نوار ابزار را بر حسب پیکسل تنظیم کنید."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "نمایش نوار ابزار پنجره موتور"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "ارتفاع نوار ابزار پنجره موتور"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "رنگ پنجره موتور - برای انتخاب، روی کنترل رنگ کلیک کنید"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "رنگ پس‌زمینه برای پنجره تحلیل موتور."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "رنگ پنل موتور - برای انتخاب، روی کنترل رنگ کلیک کنید"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "رنگ پس‌زمینه برای پنل داخلی تحلیل موتور."

#: main_18.cpp:38
msgid "Save current game"
msgstr "ذخیره بازی فعلی"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "لیست بازی‌ها از فایل فعلی"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "جستجوی پایگاه داده برای موقعیت فعلی"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "موتور در هر دو طرف نقش دارد"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "یک بازی رده‌بندی‌شده در مقابل یک موتور انجام دهید"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "تخته را برگردانید"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "یک موقعیت روی صفحه شطرنج تنظیم کنید"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "ساعت‌های بازی را تنظیم کنید"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "کتاب شروع و گزینه‌ها را انتخاب کنید"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "تنظیمات عمومی برنامه را تنظیم کنید"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "فایل راهنما را باز کنید"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "از برنامه خارج شوید"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "موتور فعلی را انتخاب کنید"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "کادر محاوره‌ای گزینه‌های تمام صفحه را باز کنید"

#: main_18.cpp:53
msgid "Close this window"
msgstr "این پنجره را ببندید"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "اضافه کردن اولین خط کیبیتس به کادر لیست جابجایی"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "تمام خطوط کیبیتس را به کادر لیست حرکت اضافه کنید"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (نسخه ۴.۲) چندزبانه،"
