#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Zaɓin cikakken allon nuni don nuna babban allon dara"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "tare da taga nazarin injin don kibitzing (sigar 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "An ƙara fasaloli zuwa Nimzo_3d - sigar 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Tagar injin"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Zaɓuɓɓukan taga injin"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Launin taga na injin"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Launin allon injin"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Zaɓi launin bayan taga injin"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Zaɓi launin allon taga na injin"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Duba don nuna kayan aikin taga injin"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Saita tsayin kayan aikin taga injin"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Nuna kayan aikin taga injin - Duba don nuna kayan aiki"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "a ƙasan tagar injin."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Tsayin kayan aikin taga na injin - Saita tsayin kayan aikin a cikin pixels."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Nuna kayan aikin taga injin"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Tsawon kayan aikin taga na injin"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Launin taga injin - Danna maɓallin sarrafa launi don zaɓar"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "launin bango don taga nazarin injin."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Launin allon injin - Danna maɓallin sarrafa launi don zaɓar"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "launin bango don ɓangaren ciki na binciken injin."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Ajiye wasan yanzu"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Jera wasanni daga fayil ɗin yanzu"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Bincika bayanai don matsayin da ake ciki a yanzu"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Injin yana wasa a ɓangarorin biyu"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Yi wasa mai daraja da injin"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Juya allon"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Saita matsayi a kan allon dara"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Saita agogon wasan"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Zaɓi littafin buɗewa da zaɓuɓɓuka"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Saita zaɓuɓɓukan gabaɗaya don shirin"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Buɗe fayil ɗin taimako"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Fita daga shirin"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Zaɓi injin na yanzu"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Buɗe akwatin tattaunawa na zaɓuɓɓukan cikakken allo"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Rufe wannan taga"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Ƙara layin kibitz na farko zuwa akwatin jerin motsi"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Ƙara duk layukan kibitz zuwa akwatin jerin motsi"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (sigar 4.2) mai harsuna da yawa,"
