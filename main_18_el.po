#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Μια επιλογή πλήρους οθόνης για την εμφάνιση μιας μεγαλύτερης σκακιέρας"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "με παράθυρο ανάλυσης μηχανής για kibitzing (έκδοση 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Χαρακτηριστικά που προστέθηκαν στο Nimzo_3d - έκδοση 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Παράθυρο κινητήρα"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Επιλογές παραθύρου κινητήρα"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Χρώμα παραθύρου κινητήρα"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Χρώμα πάνελ κινητήρα"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Επιλέξτε το χρώμα φόντου του παραθύρου της μηχανής"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Επιλέξτε το χρώμα του πάνελ του παραθύρου του κινητήρα"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Επιλέξτε για να εμφανιστεί η γραμμή εργαλείων του παραθύρου της μηχανής"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Ορισμός ύψους της γραμμής εργαλείων του παραθύρου του μηχανισμού"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Εμφάνιση γραμμής εργαλείων παραθύρου μηχανής - Επιλέξτε για να εμφανιστεί μια γραμμή εργαλείων"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "στο κάτω μέρος του παραθύρου του κινητήρα."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Ύψος γραμμής εργαλείων παραθύρου μηχανισμού - Ορίστε το ύψος της γραμμής εργαλείων σε pixel."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Εμφάνιση γραμμής εργαλείων παραθύρου μηχανής"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Ύψος γραμμής εργαλείων παραθύρου μηχανής"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Χρώμα παραθύρου μηχανής - Κάντε κλικ στο στοιχείο ελέγχου χρώματος για να επιλέξετε"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "το χρώμα φόντου για το παράθυρο ανάλυσης μηχανής."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Χρώμα πάνελ κινητήρα - Κάντε κλικ στο χειριστήριο χρώματος για να επιλέξετε"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "το χρώμα φόντου για τον εσωτερικό πίνακα ανάλυσης κινητήρα."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Αποθήκευση τρέχοντος παιχνιδιού"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Λίστα παιχνιδιών από το τρέχον αρχείο"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Αναζήτηση βάσης δεδομένων για την τρέχουσα θέση"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Η μηχανή παίζει και από τις δύο πλευρές"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Παίξτε ένα παιχνίδι με αξιολόγηση εναντίον μιας μηχανής"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Γυρίστε το ταμπλό"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Ορίστε μια θέση στην σκακιέρα"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Ρυθμίστε τα ρολόγια του παιχνιδιού"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Επιλέξτε το βιβλίο έναρξης και τις επιλογές"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Ορίστε τις γενικές επιλογές για το πρόγραμμα"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Άνοιγμα του αρχείου βοήθειας"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Έξοδος από το πρόγραμμα"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Επιλέξτε την τρέχουσα μηχανή"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Άνοιγμα του παραθύρου διαλόγου επιλογών πλήρους οθόνης"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Κλείσιμο αυτού του παραθύρου"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Προσθήκη της πρώτης γραμμής kibitz για μετακίνηση του πλαισίου λίστας"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Προσθήκη όλων των γραμμών kibitz για μετακίνηση στο πλαίσιο λίστας"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (έκδοση 4.2) πολύγλωσσο,"
