#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "אפשרות תצוגה במסך מלא להצגת לוח שחמט גדול יותר"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "עם חלון ניתוח מנוע עבור קיביטזינג (גרסה 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "תכונות שנוספו ל-Nimzo_3d - גרסה 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "חלון המנוע"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "אפשרויות חלון מנוע"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "צבע חלון המנוע"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "צבע לוח המנוע"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "בחר את צבע הרקע של חלון המנוע"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "בחירת צבע חלון המנוע"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "סמן כדי להציג את סרגל הכלים של חלון המנוע"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "הגדרת גובה סרגל הכלים של חלון המנוע"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "הצג סרגל כלים של חלון המנוע - סמן כדי להציג סרגל כלים"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "בתחתית חלון המנוע."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "גובה סרגל הכלים של חלון המנוע - הגדר את גובה סרגל הכלים בפיקסלים."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "הצג את סרגל הכלים של חלון המנוע"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "גובה סרגל הכלים של חלון המנוע"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "צבע חלון המנוע - לחץ על בקרת הצבע כדי לבחור"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "צבע הרקע עבור חלון ניתוח המנוע."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "צבע לוח המנוע - לחץ על בקרת הצבע כדי לבחור"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "צבע הרקע עבור הפאנל הפנימי של ניתוח המנוע."

#: main_18.cpp:38
msgid "Save current game"
msgstr "שמירת המשחק הנוכחי"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "רשימת משחקים מהקובץ הנוכחי"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "חפש במסד הנתונים את המשרה הנוכחית"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "המנוע משחק בשני הצדדים"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "שחק משחק מדורג נגד מנוע"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "הפוך את הלוח"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "קבע עמדה על לוח השחמט"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "כוון את שעוני המשחק"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "בחר את הספר הפותח והאפשרויות"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "הגדרת האפשרויות הכלליות עבור התוכנית"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "פתח את קובץ העזרה"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "צא מהתוכנית"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "בחר את המנוע הנוכחי"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "פתיחת תיבת הדו-שיח של אפשרויות מסך מלא"

#: main_18.cpp:53
msgid "Close this window"
msgstr "סגור את החלון הזה"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "הוסף את השורה הראשונה של קיביטז לתיבת רשימה מועברת"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "הוסף את כל שורות קיביטז לתיבת רשימה מועברת"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (גרסה 4.2) רב לשוני,"
