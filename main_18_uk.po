#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Опція повноекранного відображення для відображення більшої шахової дошки"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "з вікном аналізу двигуна для кібіцингу (версія 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Функції, додані до Nimzo_3d - версія 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Вікно двигуна"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Варіанти вікон двигуна"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Колір вікна двигуна"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Колір панелі двигуна"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Виберіть колір фону вікна двигуна"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Виберіть колір панелі вікна двигуна"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Позначте, щоб відобразити панель інструментів вікна двигуна"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Встановлення висоти панелі інструментів вікна двигуна"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Показувати панель інструментів вікна двигуна – позначте, щоб показати панель інструментів"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "у нижній частині вікна двигуна."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Висота панелі інструментів вікна двигуна – встановлення висоти панелі інструментів у пікселях."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Показати панель інструментів вікна двигуна"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Висота інструментів вікна двигуна"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Колір вікна двигуна – клацніть елемент керування кольором, щоб вибрати"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "колір фону для вікна аналізу двигуна."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Колір панелі двигуна – клацніть елемент керування кольором, щоб вибрати"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "колір фону для внутрішньої панелі аналізу двигуна."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Зберегти поточну гру"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Список ігор з поточного файлу"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Пошук у базі даних для поточної позиції"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Двигун грає в обидві сторони"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Зіграйте в рейтингову гру проти движка"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Переверніть дошку"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Встановіть позицію на шаховій дошці"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Встановіть ігрові годинники"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Виберіть початкову книгу та параметри"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Встановіть загальні параметри програми"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Відкрийте файл довідки"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Вихід з програми"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Виберіть поточний двигун"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Відкрити діалогове вікно параметрів повноекранного режиму"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Закрити це вікно"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Додати перший рядок кібіт для переміщення списку"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Додати всі кібітові рядки до списку переміщення"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (версія 4.2) багатомовна,"
