#: main_18.cpp:2
msgid "A full screen display option to show a larger chess board"
msgstr "Možnost zobrazení na celou obrazovku pro zobrazení větší šachovnice"

#: main_18.cpp:4
msgid "with a engine analysis window for kibitzing (version 4.2)"
msgstr "s oknem pro analýzu enginu pro kibitzing (verze 4.2)"

#: main_18.cpp:6
msgid "Features added to Nimzo_3d - version 4.2"
msgstr "Nové funkce do Nimzo_3d - verze 4.2"

#: main_18.cpp:8
msgid "Engine window"
msgstr "Okno motoru"

#: main_18.cpp:10
msgid "Engine window options"
msgstr "Možnosti okna motoru"

#: main_18.cpp:12
msgid "Engine window colour"
msgstr "Barva okna motoru"

#: main_18.cpp:14
msgid "Engine panel colour"
msgstr "Barva panelu motoru"

#: main_18.cpp:16
msgid "Select the engine window background colour"
msgstr "Vyberte barvu pozadí okna motoru"

#: main_18.cpp:17
msgid "Select the engine window panel colour"
msgstr "Vyberte barvu panelu okna motoru"

#: main_18.cpp:19
msgid "Check to show the engine window toolbar"
msgstr "Zaškrtněte pro zobrazení panelu nástrojů okna enginu"

#: main_18.cpp:20
msgid "Set the engine window toolbar height"
msgstr "Nastavení výšky panelu nástrojů okna enginu"

#: main_18.cpp:22
msgid "Show engine window toolbar  -  Check to show a toolbar"
msgstr "Zobrazit panel nástrojů okna enginu – Zaškrtněte pro zobrazení panelu nástrojů"

#: main_18.cpp:23
msgid "at the bottom of the engine window."
msgstr "ve spodní části okna motoru."

#: main_18.cpp:24
msgid "Engine window toolbar height  -  Set the toolbar height in pixels."
msgstr "Výška panelu nástrojů okna enginu – Nastavte výšku panelu nástrojů v pixelech."

#: main_18.cpp:27
msgid "Show engine window toolbar"
msgstr "Zobrazit nástrojovou lištu okna enginu"

#: main_18.cpp:29
msgid "Engine window toolbar height"
msgstr "Výška panelu nástrojů okna modulu"

#: main_18.cpp:31
msgid "Engine window colour  -  Click the colour control to select"
msgstr "Barva okna modulu – Kliknutím na ovládací prvek barvy jej vyberte"

#: main_18.cpp:33
msgid "the background colour for the engine analysis window."
msgstr "barva pozadí okna analýzy motoru."

#: main_18.cpp:35
msgid "Engine panel colour  -  Click the colour control to select"
msgstr "Barva panelu motoru – Kliknutím na ovládací prvek barvy jej vyberte"

#: main_18.cpp:36
msgid "the background colour for the engine analysis inner panel."
msgstr "barva pozadí pro vnitřní panel analýzy motoru."

#: main_18.cpp:38
msgid "Save current game"
msgstr "Uložit aktuální hru"

#: main_18.cpp:39
msgid "List games from current file"
msgstr "Seznam her z aktuálního souboru"

#: main_18.cpp:40
msgid "Search database for the current position"
msgstr "Vyhledávání v databázi pro aktuální pozici"

#: main_18.cpp:41
msgid "Engine plays both sides"
msgstr "Motor hraje na obě strany"

#: main_18.cpp:42
msgid "Play a rated game against an engine"
msgstr "Zahrajte si hodnocenou hru proti enginu"

#: main_18.cpp:43
msgid "Flip the board"
msgstr "Otoč hrací desku"

#: main_18.cpp:44
msgid "Setup a position on the chess board"
msgstr "Zařiďte si pozici na šachovnici"

#: main_18.cpp:45
msgid "Set the game clocks"
msgstr "Nastavte herní hodiny"

#: main_18.cpp:46
msgid "Select the opening book and options"
msgstr "Vyberte úvodní knihu a možnosti"

#: main_18.cpp:47
msgid "Set the general options for the program"
msgstr "Nastavení obecných možností programu"

#: main_18.cpp:48
msgid "Open the help file"
msgstr "Otevřít soubor s nápovědou"

#: main_18.cpp:49
msgid "Exit the program"
msgstr "Ukončete program"

#: main_18.cpp:51
msgid "Select the current engine"
msgstr "Vyberte aktuální motor"

#: main_18.cpp:52
msgid "Open the full screen options dialog box"
msgstr "Otevřít dialogové okno s možnostmi zobrazení na celou obrazovku"

#: main_18.cpp:53
msgid "Close this window"
msgstr "Zavřít toto okno"

#: main_18.cpp:54
msgid "Add first kibitz line to move list box"
msgstr "Přidat první řádek v kibitzovém kódu pro přesun seznamu"

#: main_18.cpp:55
msgid "Add all kibitz lines to move list box"
msgstr "Přidat všechny kibitzové řádky do seznamu pro přesun"

#: main_18.cpp:57
msgid "Nimzo_3d_ml (version 4.2) multi-lingual,"
msgstr "Nimzo_3d_ml (verze 4.2) vícejazyčný,"
